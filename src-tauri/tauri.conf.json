{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Parrot",
  "version": "0.1.0",
  "identifier": "com.parrot.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Parrot",
        "width": 380,
        "height": 480,
        "minWidth": 380,
        "minHeight": 480,
        "maxWidth": 380,
        "maxHeight": 480,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "focus": true
      },
      {
        "label": "tray_menu",
        "title": "Parrot Menu",
        "width": 140,
        "height": 115,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "focus": true,
        "url": "index.html?window=tray_menu"
      }
    ],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "iconPath": "icons/tray.png",
      "iconAsTemplate": false,
      "menuOnLeftClick": false
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "./icons/icon.ico",
        "installMode": "currentUser"
      }
    }
  },
  "plugins": {}
}
